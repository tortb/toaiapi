# ============================================================
# ToAIAPI Backend 环境变量配置
# 复制此文件为 .env 并填写实际值
# ============================================================

# ---- 数据库 ----
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/toaiapi?schema=public"

# ---- Redis ----
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# ---- JWT（必填，生产环境必须使用强密钥）----
JWT_SECRET="your-jwt-secret-min-32-chars"
JWT_REFRESH_SECRET="your-jwt-refresh-secret-min-32-chars"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# ---- 加密（必填，用于加密 Channel API Key）----
# 生成方式：openssl rand -hex 32
ENCRYPTION_KEY="your-64-char-hex-encryption-key"

# ---- 服务器 ----
PORT=3001
NODE_ENV="development"

# ---- CORS ----
ALLOWED_ORIGINS="http://localhost:3000"

# ---- 应用 ----
APP_URL="http://localhost:3000"

# ---- 管理员账号（Seed 初始化用）----
ADMIN_EMAIL="admin@toaiapi.com"
ADMIN_PASSWORD="Admin@123456"

# ---- SMTP 邮件服务（可选，用于密码重置邮件）----
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER="your-smtp-user"
# SMTP_PASS="your-smtp-pass"
# SMTP_FROM="noreply@toaiapi.com"
