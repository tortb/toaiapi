generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db?connection_limit=1&journal_mode=WAL&synchronous=NORMAL&cache_size=10000"
}

/// 用户表
/// 存储所有用户信息，支持邮箱/密码登录和 OAuth（GitHub/Google/微信）
/// SECURITY: password_hash 使用 Argon2id 算法
/// 支持软删除（deleted_at 字段）
model User {
  id              String            @id @default(cuid())
  email           String            @unique
  phone           String?           @unique
  password_hash   String
  display_name    String?
  avatar_url      String?
  role            UserRole          @default(USER)
  status          UserStatus        @default(ACTIVE)
  github_id       String?           @unique
  google_id       String?           @unique
  wechat_id       String?           @unique
  organization_id String?
  group_id        String?
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt
  deleted_at      DateTime?
  language                 String                    @default("zh")
  invite_code              String?                   @unique @map("invite_code")
  apiKeys                  ApiKey[]
  orders                   Order[]
  requestLogs              RequestLog[]
  organization             Organization?             @relation(fields: [organization_id], references: [id])
  group                    UserGroup?                @relation(fields: [group_id], references: [id])
  balance                  UserBalance?
  subscriptions            UserSubscription?
  transactions             UserTransaction[]
  userRoles                UserRoleMapping[]
  invoices                 Invoice[]
  notificationConfig       NotificationConfig?
  realNameVerification     RealNameVerification?
  twoFactorAuth            TwoFactorAuth?
  passkeys                 Passkey[]
  accountBindings          AccountBinding[]
  invitedBy                InviteRecord?             @relation("InviteeRelation")
  inviteRecords            InviteRecord[]            @relation("InviterRelation")
  redeemCodes              RedeemCode[]
  redeemRecords            RedeemRecord[]

  @@index([created_at])
  @@index([role])
  @@index([status])
  @@index([group_id])
  @@index([invite_code])
}

/// 用户余额表（一对一）
/// 所有金额单位：分（fen），1 元 = 100 分
model UserBalance {
  id         String   @id @default(cuid())
  user_id    String   @unique
  amount     Int      @default(0)
  frozen     Int      @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  user       User     @relation(fields: [user_id], references: [id])
}

/// 用户组表
/// 用于控制用户的价格倍率、限额、可访问模型等策略
model UserGroup {
  id               String    @id @default(cuid())
  name             String    @unique
  display_name     String
  description      String?
  price_multiplier Decimal   @default(1.0)
  rpm_limit        Int       @default(60)
  tpm_limit        Int       @default(60000)
  max_api_keys     Int       @default(10)
  allowed_models   String    @default("[]")  // JSON array
  allowed_channels String    @default("[]")  // JSON array
  allow_proxy      Boolean   @default(true)
  allow_share      Boolean   @default(false)
  is_active        Boolean   @default(true)
  is_builtin       Boolean   @default(false)
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  deleted_at       DateTime?
  users            User[]
  apiKeys          ApiKey[]

  @@index([is_active])
  @@index([deleted_at])
}

// ============================================================
// RBAC 权限系统
// ============================================================

/// 角色表
model Role {
  id          String    @id @default(cuid())
  code        String    @unique  // 角色编码（super_admin / admin / finance 等）
  name        String             // 显示名
  description String?
  level       Int       @default(0)  // 角色等级（super_admin=100 / admin=80 / user=10）
  is_system   Boolean   @default(false)  // 系统内置角色不可删除
  is_active   Boolean   @default(true)
  data_scope  String    @default("SELF")  // 数据范围：ALL / ORGANIZATION / SELF

  user_roles  UserRoleMapping[]
  permissions RolePermission[]
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  deleted_at  DateTime?

  @@index([is_active])
  @@index([level])
  @@index([deleted_at])
}

/// 权限点表
model Permission {
  id          String   @id @default(cuid())
  code        String   @unique  // 权限编码（user:create / order:refund 等）
  name        String            // 显示名
  resource    String            // 资源域（user / order / model / system）
  action      String            // 操作（create / read / update / delete）
  description String?

  roles       RolePermission[]
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([resource])
  @@index([action])
}

/// 角色-权限关联表
model RolePermission {
  id            String     @id @default(cuid())
  role_id       String
  role          Role       @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permission_id String
  permission    Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)
  created_at    DateTime   @default(now())

  @@unique([role_id, permission_id])
  @@index([role_id])
  @@index([permission_id])
}

/// 用户-角色关联表
model UserRoleMapping {
  id         String    @id @default(cuid())
  user_id    String
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  role_id    String
  role       Role      @relation(fields: [role_id], references: [id], onDelete: Restrict)
  granted_by String?
  granted_at DateTime  @default(now())
  expires_at DateTime?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  @@unique([user_id, role_id])
  @@index([user_id])
  @@index([role_id])
  @@index([expires_at])
}

/// 交易流水表
/// 记录所有余额变动，支持审计和对账
model UserTransaction {
  id            String          @id @default(cuid())
  user_id       String
  type          TransactionType
  amount        Int
  balance_after Int
  order_id      String?
  remark        String?
  created_at    DateTime        @default(now())
  user          User            @relation(fields: [user_id], references: [id])

  @@index([user_id, created_at])
  @@index([order_id])
}

/// API Key 表
/// SECURITY: key_hash 使用 Argon2id 哈希，不存储明文
/// key_prefix 存储前 16 字符用于列表展示
model ApiKey {
  id              String    @id @default(cuid())
  user_id         String
  key_hash        String    @unique
  key_prefix      String
  name            String?
  is_active       Boolean   @default(true)
  expires_at      DateTime?
  rate_limit      Int?
  token_limit     Int?
  model_limit     String    @default("[]")  // JSON array
  ip_whitelist    String    @default("[]")  // JSON array
  last_used_at    DateTime?
  total_requests  Int       @default(0)
  group_id        String?   @map("group_id")
  rpm_limit       Int?      @map("rpm_limit")
  tpm_limit       Int?      @map("tpm_limit")
  unlimited_quota Boolean   @default(false) @map("unlimited_quota")
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  user            User      @relation(fields: [user_id], references: [id])
  group           UserGroup? @relation(fields: [group_id], references: [id])

  @@index([user_id])
  @@index([key_prefix])
  @@index([group_id])
}

/// AI 模型定义表
/// 存储支持的 AI 模型及其能力（流式/工具/视觉）
model Model {
  id                 String         @id @default(cuid())
  name               String         @unique
  display_name       String
  provider_id        String
  max_context        Int
  supports_streaming Boolean        @default(true)
  supports_tools     Boolean        @default(false)
  supports_vision    Boolean        @default(false)
  is_active          Boolean        @default(true)
  created_at         DateTime       @default(now())
  updated_at         DateTime       @updatedAt
  channels           ChannelModel[]
  pricing            ModelPricing?
}

/// 模型定价表（一对一）
/// 价格单位：分/百万 Token
model ModelPricing {
  id              String   @id @default(cuid())
  model_id        String   @unique
  input_price     Int
  output_price    Int
  cached_price    Int?
  reasoning_price Int?
  multiplier      Decimal  @default(1.0)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  model           Model    @relation(fields: [model_id], references: [id])
}

/// AI 服务商表（如 OpenAI、Anthropic、Google）
model Provider {
  id           String    @id @default(cuid())
  name         String    @unique
  display_name String
  base_url     String
  is_active    Boolean   @default(true)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  channels     Channel[]
}

/// 渠道表
/// 每个渠道对应一个 Provider 的一个 API 端点/凭证
/// SECURITY: api_key 使用 AES-256-GCM 加密存储
model Channel {
  id                        String         @id @default(cuid())
  provider_id               String
  name                      String
  base_url                  String
  api_key                   String
  weight                    Int            @default(1)
  priority                  Int            @default(0)
  is_active                 Boolean        @default(true)
  status                    ChannelStatus  @default(ACTIVE)
  total_requests            Int            @default(0)
  failed_requests           Int            @default(0)
  avg_latency_ms            Int            @default(0)
  rate_limit                Int?
  token_limit               Int?
  org_id                    String?        @map("org_id")
  auto_disable              Boolean        @default(false) @map("auto_disable")
  tags                      String?
  internal_note             String?        @map("internal_note")
  status_mapping            String?        @map("status_mapping")
  param_override            String?        @map("param_override")
  header_override           String?        @map("header_override")
  proxy                     String?
  system_prompt             String?        @map("system_prompt")
  concat_prompt             Boolean        @default(false) @map("concat_prompt")
  passthrough_service_tier  Boolean        @default(false) @map("passthrough_service_tier")
  block_store               Boolean        @default(false) @map("block_store")
  passthrough_safety_id     Boolean        @default(false) @map("passthrough_safety_id")
  passthrough_include       Boolean        @default(false) @map("passthrough_include")
  passthrough_inference_geo Boolean        @default(false) @map("passthrough_inference_geo")
  force_openai_format       Boolean        @default(false) @map("force_openai_format")
  reasoning_to_think_tag    Boolean        @default(false) @map("reasoning_to_think_tag")
  passthrough_body          Boolean        @default(false) @map("passthrough_body")
  detect_upstream           Boolean        @default(false) @map("detect_upstream")
  auto_sync_models          Boolean        @default(false) @map("auto_sync_models")
  exclude_model_regex       String?        @map("exclude_model_regex")
  last_detect_time          DateTime?      @map("last_detect_time")
  detected_models           String?        @map("detected_models")
  key_mode                  String         @default("single") @map("key_mode")
  api_keys                  String?        @map("api_keys")
  created_at                DateTime       @default(now())
  updated_at                DateTime       @updatedAt
  provider                  Provider       @relation(fields: [provider_id], references: [id])
  models                    ChannelModel[]

  @@index([provider_id, is_active])
}

/// 渠道-模型关联表（多对多）
/// 一个渠道可以支持多个模型，一个模型可以有多个渠道
model ChannelModel {
  id         String  @id @default(cuid())
  channel_id String
  model_id   String
  alias      String?
  is_active  Boolean @default(true)
  channel    Channel @relation(fields: [channel_id], references: [id])
  model      Model   @relation(fields: [model_id], references: [id])

  @@unique([channel_id, model_id])
}

/// 订单表
/// 金额单位：分（fen）
model Order {
  id             String         @id @default(cuid())
  order_no       String         @unique
  user_id        String
  amount         Int
  paid_amount    Int?
  payment_method PaymentMethod?
  status         OrderStatus    @default(PENDING)
  product_type   String
  product_id     String?
  product_name   String
  paid_at        DateTime?
  expired_at     DateTime?
  remark         String?
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt
  user           User           @relation(fields: [user_id], references: [id])
  payment        Payment?

  @@index([user_id, created_at])
  @@index([status])
}

/// 支付记录表（一对一关联 Order）
model Payment {
  id            String        @id @default(cuid())
  order_id      String        @unique
  method        PaymentMethod
  amount        Int
  trade_no      String?
  buyer_id      String?
  status        PaymentStatus @default(PENDING)
  paid_at       DateTime?
  refunded_at   DateTime?
  refund_amount Int?
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
  order         Order         @relation(fields: [order_id], references: [id])
}

/// 订阅计划表
/// 定义可用的订阅套餐及其配额和限制
model SubscriptionPlan {
  id            String             @id @default(cuid())
  name          String             @unique
  display_name  String
  monthly_price Int
  yearly_price  Int
  monthly_quota Int
  rate_limit    Int
  token_limit   Int
  features      Json
  is_active     Boolean            @default(true)
  created_at    DateTime           @default(now())
  updated_at    DateTime           @updatedAt
  subscriptions UserSubscription[]
}

/// 用户订阅表（一对一）
model UserSubscription {
  id         String             @id @default(cuid())
  user_id    String             @unique
  plan_id    String
  type       SubscriptionType
  period     String
  start_date DateTime
  end_date   DateTime
  used_quota Int                @default(0)
  auto_renew Boolean            @default(true)
  status     SubscriptionStatus @default(ACTIVE)
  created_at DateTime           @default(now())
  updated_at DateTime           @updatedAt
  plan       SubscriptionPlan   @relation(fields: [plan_id], references: [id])
  user       User               @relation(fields: [user_id], references: [id])
}

/// 企业组织表
/// 支持多租户，一个组织有多个成员
model Organization {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  balance    Int      @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  members    User[]
}

/// API 请求日志表
/// 记录每次 API 调用的详细信息，用于计费审计和使用统计
/// 注意：不设外键约束，避免高频写入时的锁竞争
model RequestLog {
  id                String   @id @default(cuid())
  user_id           String
  api_key_id        String
  model_id          String
  channel_id        String
  request_path      String
  request_method    String
  prompt_tokens     Int
  completion_tokens Int
  cached_tokens     Int      @default(0)
  reasoning_tokens  Int      @default(0)
  total_tokens      Int
  cost              Int
  status_code       Int
  latency_ms        Int
  created_at        DateTime @default(now())
  user              User     @relation(fields: [user_id], references: [id])

  @@index([user_id, created_at])
  @@index([model_id, created_at])
  @@index([channel_id, created_at])
  @@index([created_at])
  @@map("request_logs")
}

/// 支付渠道配置表
/// 存储各支付渠道的商户配置信息
/// SECURITY: 敏感字段使用 AES-256-GCM 加密存储
model PaymentConfig {
  id              String   @id @default(cuid())
  name            String   @unique
  display_name    String
  is_enabled      Boolean  @default(false)
  merchant_id     String?
  merchant_key    String?
  merchant_secret String?
  api_endpoint    String?
  notify_url      String?
  return_url      String?
  extra_config    Json?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
}

/// SMTP邮件配置表
/// 存储邮件服务器配置
/// SECURITY: 密码使用 AES-256-GCM 加密存储
model SmtpConfig {
  id           String   @id @default(cuid())
  name         String   @unique
  is_enabled   Boolean  @default(false)
  host         String?
  port         Int      @default(587)
  secure       Boolean  @default(false)
  username     String?
  password     String?
  from_name    String?
  from_address String?
  extra_config Json?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
}

/// 短信配置表
/// 存储阿里云短信服务配置
/// SECURITY: access_key_secret 使用 AES-256-GCM 加密存储
model SmsConfig {
  id                String   @id @default(cuid())
  name              String   @unique
  display_name      String
  is_enabled        Boolean  @default(false)
  access_key_id     String?
  access_key_secret String?
  sign_name         String?
  template_code     String?
  extra_config      Json?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
}

enum UserRole {
  USER
  VIP
  ENTERPRISE
  AGENT
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum TransactionType {
  RECHARGE
  DEDUCT
  REFUND
  GIFT
  REWARD
  FREEZE
  UNFREEZE
}

enum ChannelStatus {
  ACTIVE
  RATE_LIMITED
  ERROR
  DISABLED
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  WECHAT_PAY
  ALIPAY
  EPAY_ALIPAY
  EPAY_WECHAT
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum SubscriptionType {
  PAY_AS_YOU_GO
  SUBSCRIPTION
  HYBRID
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  SUSPENDED
}

// ──────────────────────────────────────────────
// 充值赠送活动
// ──────────────────────────────────────────────

model RechargePromotion {
  id          String    @id @default(cuid())
  name        String                                  // 活动名称
  description String?                                 // 活动描述
  min_amount  Int                                     // 最低充值金额（分）
  bonus_type  BonusType                               // FIXED=固定金额, PERCENTAGE=百分比
  bonus_value Int                                     // 赠送值（分或百分比×100，如10%存1000）
  max_bonus   Int?                                    // 百分比模式上限（分）
  start_at    DateTime                                // 生效时间
  end_at      DateTime?                               // 结束时间（null=永久）
  is_active   Boolean   @default(true)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  @@index([is_active, start_at, end_at])
}

enum BonusType {
  FIXED       // 固定金额赠送（如充100送10）
  PERCENTAGE  // 百分比赠送（如充100送10%）
}

// ──────────────────────────────────────────────
// 发票
// ──────────────────────────────────────────────

model Invoice {
  id              String        @id @default(cuid())
  invoice_no      String        @unique           // 发票号
  user_id         String
  user            User          @relation(fields: [user_id], references: [id], onDelete: Restrict)
  type            InvoiceType                     // COMPANY=企业, PERSONAL=个人
  company_name    String?                         // 公司名称
  tax_id          String?                         // 税号
  company_address String?                         // 公司地址
  company_phone   String?                         // 公司电话
  bank_name       String?                         // 开户银行
  bank_account    String?                         // 银行账号（加密）
  amount          Int                             // 发票金额（分）
  content         String        @default("技术服务费")  // 发票内容
  status          InvoiceStatus @default(PENDING)
  applicant_email String                          // 申请人邮箱
  applicant_phone String?                         // 申请人电话
  mailing_address String?                         // 邮寄地址
  file_url        String?                         // 发票 PDF/图片 URL
  reviewed_at     DateTime?                       // 审核时间
  reviewed_by     String?                         // 审核人
  review_remark   String?                         // 审核备注
  issued_at       DateTime?                       // 开具时间
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  @@index([user_id, status])
  @@index([status, created_at])
}

enum InvoiceType {
  COMPANY     // 企业发票
  PERSONAL    // 个人发票
}

enum InvoiceStatus {
  PENDING     // 待审核
  APPROVED    // 已通过
  REJECTED    // 已驳回
  ISSUED      // 已开具
  CANCELLED   // 已取消
}

// ──────────────────────────────────────────────
// 系统参数配置（通用 KV 存储）
// ──────────────────────────────────────────────

/// 系统参数配置表
/// 支持 15 个分类的系统设置，新增设置无需改表结构
/// value 统一存储为字符串，type 字段标识原始类型
model SystemSetting {
  id         String   @id @default(cuid())
  category   String              // 分类：basic/website/user/register/email/payment/finance/model/provider/rate_limit/security/api/notification/storage/developer
  key        String   @unique    // 键名，如 site_name
  value      String?             // 值（JSON 字符串或原始值）
  type       String   @default("string") // string/number/boolean/json
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([category])
}


// ──────────────────────────────────────────────
// 通知配置
// ──────────────────────────────────────────────

/// 通知配置表（一对一）
model NotificationConfig {
  id                     String   @id @default(cuid())
  user_id                String   @unique @map("user_id")
  email                  String?                       // 通知邮箱（留空使用账号邮箱）
  low_balance_threshold  Int      @default(10000)     // 预警额度（分）
  subscriptions          String   @default("[]")      // JSON: string[]
  channels               String   @default("{}")      // JSON: ChannelConfig
  updated_at             DateTime @updatedAt
  created_at             DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("notification_configs")
}

// ──────────────────────────────────────────────
// 实名认证
// ──────────────────────────────────────────────

/// 实名认证表（一对一）
model RealNameVerification {
  id               String    @id @default(cuid())
  user_id          String    @unique @map("user_id")
  real_name        String    @map("real_name")
  id_card          String    @map("id_card")          // AES-256-GCM 加密
  front_image_url  String?   @map("front_image_url")
  back_image_url   String?   @map("back_image_url")
  status           String    @default("PENDING")      // PENDING/APPROVED/REJECTED
  reject_reason    String?   @map("reject_reason")
  verified_at      DateTime? @map("verified_at")
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("real_name_verifications")
}

// ──────────────────────────────────────────────
// 兑换码
// ──────────────────────────────────────────────

/// 兑换码表
model RedeemCode {
  id          String        @id @default(cuid())
  code        String        @unique                  // 兑换码（大写字母+数字）
  type        String        @default("FIXED")        // FIXED/PERCENTAGE
  value       Int                                    // 固定额度（分）或百分比
  max_uses    Int           @default(1)  @map("max_uses")
  used_count  Int           @default(0)  @map("used_count")
  expires_at  DateTime?     @map("expires_at")
  is_active   Boolean       @default(true) @map("is_active")
  created_by  String        @map("created_by")
  created_at  DateTime      @default(now())
  updated_at  DateTime      @updatedAt

  user    User           @relation(fields: [created_by], references: [id])
  records RedeemRecord[]

  @@index([code])
  @@index([is_active, expires_at])
  @@map("redeem_codes")
}

/// 兑换记录表
model RedeemRecord {
  id         String   @id @default(cuid())
  user_id    String   @map("user_id")
  code_id    String   @map("code_id")
  reward     Int                      // 奖励额度（分）
  created_at DateTime @default(now())

  user User       @relation(fields: [user_id], references: [id])
  code RedeemCode @relation(fields: [code_id], references: [id])

  @@index([user_id])
  @@map("redeem_records")
}

// ──────────────────────────────────────────────
// 邀请奖励
// ──────────────────────────────────────────────

/// 邀请记录表
model InviteRecord {
  id              String   @id @default(cuid())
  inviter_id      String   @map("inviter_id")        // 邀请人
  invitee_id      String   @unique @map("invitee_id") // 被邀请人
  reward          Int      @default(0)               // 已获得奖励（分）
  pending_reward  Int      @default(0) @map("pending_reward") // 待确认奖励（分）
  recharge_count  Int      @default(0) @map("recharge_count") // 被邀请人充值次数
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  inviter User @relation("InviterRelation", fields: [inviter_id], references: [id])
  invitee User @relation("InviteeRelation", fields: [invitee_id], references: [id])

  @@index([inviter_id])
  @@map("invite_records")
}

// ──────────────────────────────────────────────
// 账户安全
// ──────────────────────────────────────────────

/// 账户绑定表
model AccountBinding {
  id            String   @id @default(cuid())
  user_id       String   @map("user_id")
  provider      String                       // EMAIL/GITHUB/GOOGLE/WECHAT
  provider_id   String   @map("provider_id") // 平台ID
  email         String?
  access_token  String?  @map("access_token")  // AES-256-GCM 加密
  refresh_token String?  @map("refresh_token") // AES-256-GCM 加密
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, provider])
  @@index([provider, provider_id])
  @@map("account_bindings")
}

/// 两步验证表（一对一）
model TwoFactorAuth {
  id           String    @id @default(cuid())
  user_id      String    @unique @map("user_id")
  secret       String                        // TOTP secret (AES-256-GCM 加密)
  is_enabled   Boolean   @default(false) @map("is_enabled")
  last_used_at DateTime? @map("last_used_at")
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("two_factor_auths")
}

/// Passkey 表
model Passkey {
  id            String    @id @default(cuid())
  user_id       String    @map("user_id")
  credential_id String    @unique @map("credential_id")
  public_key    String    @map("public_key") // 公钥（JSON）
  device_name   String?   @map("device_name")
  last_used_at  DateTime? @map("last_used_at")
  created_at    DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("passkeys")
}

// ──────────────────────────────────────────────
// 排行榜与分析
// ──────────────────────────────────────────────

/// 排行榜缓存表
model LeaderboardCache {
  id         String   @id @default(cuid())
  period     String              // TODAY/WEEK/MONTH/YEAR/ALL
  data_type  String   @map("data_type") // MODELS/VENDORS/TRENDING/AGGREGATE
  data       String              // JSON 缓存数据
  expires_at DateTime @map("expires_at")
  created_at DateTime @default(now())

  @@unique([period, data_type])
  @@index([expires_at])
  @@map("leaderboard_cache")
}

// ──────────────────────────────────────────────
// API 快捷方式
// ──────────────────────────────────────────────

/// API 快捷方式表
model ApiShortcut {
  id          String   @id @default(cuid())
  url         String
  name        String
  description String?
  color       String   @default("blue") // blue/red/green/yellow/purple/orange/teal/indigo
  sort_order  Int      @default(0) @map("sort_order")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("api_shortcuts")
}

// ──────────────────────────────────────────────
// Uptime Kuma 监控
// ──────────────────────────────────────────────

/// Uptime Kuma 分组表
model UptimeGroup {
  id         String   @id @default(cuid())
  name       String              // 显示名称（最多50字符）
  base_url   String   @map("base_url")
  slug       String              // 别名，URL变为 {baseUrl}/status/{slug}
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("uptime_groups")
}

// ──────────────────────────────────────────────
// Provider 专属设置
// ──────────────────────────────────────────────

/// Provider 专属设置表
model ProviderSetting {
  id          String   @id @default(cuid())
  provider_id String   @unique @map("provider_id")
  settings    String              // JSON - 安全行为/版本覆盖等
  updated_at  DateTime @updatedAt
  created_at  DateTime @default(now())

  @@map("provider_settings")
}

// ──────────────────────────────────────────────
// 渠道亲和性
// ──────────────────────────────────────────────

/// 渠道亲和性规则表
model ChannelAffinityRule {
  id          String   @id @default(cuid())
  name        String
  model_regex String   @map("model_regex")
  key_source  String   @map("key_source")  // gjson:path 或 header:name
  ttl         Int      @default(3600)      // 缓存TTL(秒)
  retry       Boolean  @default(false)
  scope       String   @default("GROUP")   // GROUP/RULE
  cache_count Int      @default(0) @map("cache_count")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("channel_affinity_rules")
}

/// 渠道亲和性配置表
model ChannelAffinityConfig {
  id               String   @id @default(cuid())
  max_entries      Int      @default(100000) @map("max_entries")
  default_ttl      Int      @default(3600)   @map("default_ttl")
  update_on_retry  Boolean  @default(true)   @map("update_on_retry")
  updated_at       DateTime @updatedAt
  created_at       DateTime @default(now())

  @@map("channel_affinity_config")
}

// ──────────────────────────────────────────────
// 支付网关配置
// ──────────────────────────────────────────────

/// 支付网关配置表
model PaymentGatewayConfig {
  id         String   @id @default(cuid())
  gateway    String   @unique // STRIPE/CREEM/WAFFO_PANCAKE/WAFFO_AGGREGATE
  config     String              // JSON - 包含所有配置(AES加密敏感字段)
  is_enabled Boolean  @default(false) @map("is_enabled")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("payment_gateway_configs")
}

/// 充值折扣表
model RechargeDiscount {
  id            String   @id @default(cuid())
  min_amount    Int      @map("min_amount")    // 最低充值金额（分）
  discount_rate Float    @map("discount_rate") // 折扣率 (9.90折 = 0.99)
  bonus_percent Float    @default(0) @map("bonus_percent") // 赠送百分比
  is_active     Boolean  @default(true) @map("is_active")
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("recharge_discounts")
}
