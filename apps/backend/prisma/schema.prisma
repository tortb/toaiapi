// ToAIAPI Database Schema
// 所有数据库变更必须通过 Prisma Migration

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 用户系统
// ============================================================

/// 用户表
/// 存储所有用户信息，支持邮箱/密码登录和 OAuth（GitHub/Google/微信）
/// SECURITY: password_hash 使用 Argon2id 算法
/// 支持软删除（deleted_at 字段）
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  phone         String?   @unique
  password_hash String
  display_name  String?
  avatar_url    String?
  role          UserRole  @default(USER)
  status        UserStatus @default(ACTIVE)

  // OAuth
  github_id     String?   @unique
  google_id     String?   @unique
  wechat_id     String?   @unique

  // 关联
  balance       UserBalance?
  apiKeys       ApiKey[]
  subscriptions UserSubscription[]
  orders        Order[]
  transactions  UserTransaction[]
  requestLogs   RequestLog[]
  organization  Organization? @relation(fields: [organization_id], references: [id])
  organization_id String?

  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?

  @@index([created_at])
  @@index([role])
  @@index([status])
}

enum UserRole {
  USER
  VIP
  ENTERPRISE
  AGENT
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

// ============================================================
// 余额系统
// ============================================================

/// 用户余额表（一对一）
/// 所有金额单位：分（fen），1 元 = 100 分
model UserBalance {
  id         String   @id @default(cuid())
  user_id    String   @unique
  user       User     @relation(fields: [user_id], references: [id])

  // 余额单位：分
  amount     Int      @default(0)
  // 冻结金额
  frozen     Int      @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

/// 交易流水表
/// 记录所有余额变动，支持审计和对账
model UserTransaction {
  id            String          @id @default(cuid())
  user_id       String
  user          User            @relation(fields: [user_id], references: [id])

  type          TransactionType
  amount        Int
  balance_after Int

  order_id      String?
  remark        String?

  created_at    DateTime        @default(now())

  @@index([user_id, created_at])
  @@index([order_id])
}

enum TransactionType {
  RECHARGE
  DEDUCT
  REFUND
  GIFT
  REWARD
  FREEZE
  UNFREEZE
}

// ============================================================
// API Key 系统
// ============================================================

/// API Key 表
/// SECURITY: key_hash 使用 Argon2id 哈希，不存储明文
/// key_prefix 存储前 16 字符用于列表展示
model ApiKey {
  id          String    @id @default(cuid())
  user_id     String
  user        User      @relation(fields: [user_id], references: [id])

  key_hash    String    @unique
  key_prefix  String    // sk-toai-xxxxxx (前16位，用于展示)
  name        String?

  is_active   Boolean   @default(true)
  expires_at  DateTime?

  // 限制
  rate_limit  Int?      // 请求/分钟
  token_limit Int?      // token/分钟
  model_limit String[]  // 允许的模型列表

  // IP 白名单
  ip_whitelist String[]

  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  @@index([user_id])
  @@index([key_prefix])
}

// ============================================================
// 模型系统
// ============================================================

/// AI 模型定义表
/// 存储支持的 AI 模型及其能力（流式/工具/视觉）
model Model {
  id              String    @id @default(cuid())
  name            String    @unique  // 'claude-sonnet-4', 'gpt-4o'
  display_name    String
  provider_id     String

  max_context     Int
  supports_streaming Boolean @default(true)
  supports_tools     Boolean @default(false)
  supports_vision    Boolean @default(false)

  is_active       Boolean   @default(true)

  pricing         ModelPricing?
  channels        ChannelModel[]
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
}

/// 模型定价表（一对一）
/// 价格单位：分/百万 Token
model ModelPricing {
  id              String   @id @default(cuid())
  model_id        String   @unique
  model           Model    @relation(fields: [model_id], references: [id])

  // 价格单位：分/百万 token
  input_price     Int
  output_price    Int
  cached_price    Int?
  reasoning_price Int?

  multiplier      Decimal  @default(1.0)

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
}

// ============================================================
// 渠道系统
// ============================================================

/// AI 服务商表（如 OpenAI、Anthropic、Google）
model Provider {
  id          String    @id @default(cuid())
  name        String    @unique  // 'openai', 'anthropic', 'google'
  display_name String
  base_url    String

  is_active   Boolean   @default(true)
  channels    Channel[]

  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
}

/// 渠道表
/// 每个渠道对应一个 Provider 的一个 API 端点/凭证
/// SECURITY: api_key 使用 AES-256-GCM 加密存储
model Channel {
  id           String    @id @default(cuid())
  provider_id  String
  provider     Provider  @relation(fields: [provider_id], references: [id])
  name         String
  base_url     String
  api_key      String    // 加密存储

  weight       Int       @default(1)
  priority     Int       @default(0)

  is_active    Boolean   @default(true)
  status       ChannelStatus @default(ACTIVE)

  total_requests Int     @default(0)
  failed_requests Int    @default(0)
  avg_latency_ms Int     @default(0)

  rate_limit   Int?
  token_limit  Int?

  models       ChannelModel[]
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  @@index([provider_id, is_active])
}

/// 渠道-模型关联表（多对多）
/// 一个渠道可以支持多个模型，一个模型可以有多个渠道
model ChannelModel {
  id          String  @id @default(cuid())
  channel_id  String
  channel     Channel @relation(fields: [channel_id], references: [id])
  model_id    String
  model       Model   @relation(fields: [model_id], references: [id])

  alias       String?
  is_active   Boolean @default(true)

  @@unique([channel_id, model_id])
}

enum ChannelStatus {
  ACTIVE
  RATE_LIMITED
  ERROR
  DISABLED
}

// ============================================================
// 订单系统
// ============================================================

/// 订单表
/// 金额单位：分（fen）
model Order {
  id           String      @id @default(cuid())
  order_no     String      @unique
  user_id      String
  user         User        @relation(fields: [user_id], references: [id])

  amount       Int
  paid_amount  Int?

  payment_method PaymentMethod?

  status       OrderStatus @default(PENDING)

  product_type String
  product_id   String?
  product_name String

  paid_at      DateTime?
  expired_at   DateTime?
  remark       String?

  payment      Payment?

  created_at   DateTime    @default(now())
  updated_at   DateTime    @updatedAt

  @@index([user_id, created_at])
  @@index([status])
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  WECHAT_PAY
  ALIPAY
}

// ============================================================
// 支付系统
// ============================================================

/// 支付记录表（一对一关联 Order）
model Payment {
  id              String        @id @default(cuid())
  order_id        String        @unique
  order           Order         @relation(fields: [order_id], references: [id])

  method          PaymentMethod
  amount          Int

  // 第三方支付信息
  trade_no        String?
  buyer_id        String?

  status          PaymentStatus @default(PENDING)

  paid_at         DateTime?
  refunded_at     DateTime?
  refund_amount   Int?

  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

// ============================================================
// 套餐系统
// ============================================================

/// 订阅计划表
/// 定义可用的订阅套餐及其配额和限制
model SubscriptionPlan {
  id              String   @id @default(cuid())
  name            String   @unique
  display_name    String

  monthly_price   Int
  yearly_price    Int

  monthly_quota   Int

  rate_limit      Int
  token_limit     Int

  features        Json

  is_active       Boolean  @default(true)

  subscriptions   UserSubscription[]

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
}

/// 用户订阅表（一对一）
model UserSubscription {
  id              String           @id @default(cuid())
  user_id         String           @unique
  user            User             @relation(fields: [user_id], references: [id])
  plan_id         String
  plan            SubscriptionPlan @relation(fields: [plan_id], references: [id])

  type            SubscriptionType

  period          String
  start_date      DateTime
  end_date        DateTime

  used_quota      Int              @default(0)

  auto_renew      Boolean          @default(true)

  status          SubscriptionStatus @default(ACTIVE)
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt
}

enum SubscriptionType {
  PAY_AS_YOU_GO
  SUBSCRIPTION
  HYBRID
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  SUSPENDED
}

// ============================================================
// 企业系统
// ============================================================

/// 企业组织表
/// 支持多租户，一个组织有多个成员
model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique

  // 企业余额
  balance     Int      @default(0)

  members     User[]

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

// ============================================================
// 请求日志
// ============================================================

/// API 请求日志表
/// 记录每次 API 调用的详细信息，用于计费审计和使用统计
/// 注意：不设外键约束，避免高频写入时的锁竞争
model RequestLog {
  id                String   @id @default(cuid())
  user_id           String
  user              User     @relation(fields: [user_id], references: [id])
  api_key_id        String
  model_id          String
  channel_id        String

  request_path      String
  request_method    String

  prompt_tokens     Int
  completion_tokens Int
  cached_tokens     Int      @default(0)
  reasoning_tokens  Int      @default(0)
  total_tokens      Int

  cost              Int

  status_code       Int
  latency_ms        Int

  created_at        DateTime @default(now())

  @@index([user_id, created_at])
  @@index([model_id, created_at])
  @@index([channel_id, created_at])
  @@index([created_at])
}
