{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "module": "commonjs",
    "moduleResolution": "node",
    "declaration": true,
    "incremental": false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.js", "src/**/*.d.ts", "dist"]
}
