# ToAIAPI Environment Configuration
# Copy this file to .env and fill in the values

# ============================================================
# Application
# ============================================================

NODE_ENV=development
PORT=3001

# ============================================================
# Admin Account (for seed)
# ============================================================

ADMIN_EMAIL=admin@toaiapi.com
ADMIN_PASSWORD=Admin@123456

# ============================================================
# Database
# ============================================================

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=toaiapi
POSTGRES_PASSWORD=toaiapi123
POSTGRES_DB=toaiapi
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=toaiapi123
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}

# ============================================================
# Authentication
# ============================================================

JWT_SECRET=your-jwt-secret-here-change-in-production
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ============================================================
# Encryption
# ============================================================

# AES-256-GCM 密钥（32 字节 hex 格式，用于加密 Channel API Key）
# 生成方式：openssl rand -hex 32
ENCRYPTION_KEY=your-32-byte-encryption-key-in-hex-change-me

# ============================================================
# Frontend
# ============================================================

# 对于前端到后端的公开 API 请求基地址（必须为绝对 URL），
# 推荐在本地开发时设置为后端服务地址，例如 http://localhost:3001
# 在部署环境中请设置为 https://api.yourdomain.com 或使用平台提供的 VERCEL_URL
NEXT_PUBLIC_API_BASE=http://localhost:3001
# 兼容旧变量名（可选）
NEXT_PUBLIC_API_URL=http://localhost:3001

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002

# ============================================================
# Payment - WeChat Pay
# ============================================================

WECHAT_PAY_APPID=
WECHAT_PAY_MCHID=
WECHAT_PAY_API_KEY=
WECHAT_PAY_CERT_PATH=
WECHAT_PAY_KEY_PATH=
WECHAT_PAY_NOTIFY_URL=

# ============================================================
# Payment - Alipay
# ============================================================

ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=
ALIPAY_RETURN_URL=

# ============================================================
# SMS - Tencent Cloud
# ============================================================

TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=

# ============================================================
# SMS - Aliyun
# ============================================================

ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=

# ============================================================
# Content Safety
# ============================================================

ALIYUN_CONTENT_SAFETY_ACCESS_KEY_ID=
ALIYUN_CONTENT_SAFETY_ACCESS_KEY_SECRET=

# ============================================================
# Real-Name Verification
# ============================================================

TENCENT_FACEID_SECRET_ID=
TENCENT_FACEID_SECRET_KEY=

# ============================================================
# OAuth
# ============================================================

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_CALLBACK_URL=
