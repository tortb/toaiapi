{
  "name": "toaiapi-e2e-tests",
  "version": "1.0.0",
  "private": true,
  "description": "ToAIAPI 端到端测试 (Playwright)",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:auth": "playwright test tests/auth.spec.ts",
    "test:apikeys": "playwright test tests/apikeys.spec.ts",
    "test:navigation": "playwright test tests/navigation.spec.ts",
    "test:api": "playwright test tests/api-gateway.spec.ts",
    "report": "playwright show-report",
    "install:browsers": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
