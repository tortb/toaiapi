  "description": "Enterprise AI Gateway Platform",
  "keywords": [
    "ai",
    "gateway",
    "openai",
    "claude",
    "gemini",
    "deepseek",
    "api",
    "billing",
    "saas"
  ],
  "homepage": "https://toaiapi.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/toaiapi.git"
  },
  "license": "MIT",
  "author": "ToAIAPI Team",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "clean": "turbo clean",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:push": "turbo db:push",
    "db:studio": "turbo db:studio",
    "db:seed": "turbo db:seed",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "prettier": "^3.3.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
